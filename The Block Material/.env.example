# Supabase PostgreSQL connection (pooled - for application queries)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require"

# Supabase PostgreSQL connection (direct - for migrations)
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?sslmode=require"

# Required — used to sign session cookies.
# Generate with: openssl rand -hex 32
JWT_SECRET="your-jwt-secret-here"
