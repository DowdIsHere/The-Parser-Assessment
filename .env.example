# Stripe API Credentials
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Server
PORT=3000
SESSION_SECRET=replace-with-a-long-random-string

# Promo Codes
# PROMO_FREE - Code that grants 100% discount (completely free)
# PROMO_DISCOUNT - Code that grants 15% discount
PROMO_FREE=FREE2DAY4
PROMO_DISCOUNT=SAVE15

# Email Configuration (SiteGround SMTP — host is hardcoded to mail.cognitionblocksllc.com)
# EMAIL_USER = the full SiteGround email address you send FROM (e.g. noreply@cognitionblocksllc.com)
# EMAIL_PASS = the SiteGround password for that email account
# EMAIL_FROM = optional display name, defaults to EMAIL_USER
EMAIL_USER=noreply@cognitionblocksllc.com
EMAIL_PASS=your-siteground-email-password
EMAIL_FROM=Parser Profile <noreply@cognitionblocksllc.com>
