# Square API Credentials
# Get these from https://developer.squareup.com/apps

# Sandbox (testing)
# Note: Sandbox Location ID format is typically like: C48SWGPW8D1T2
SQUARE_ACCESS_TOKEN=your_sandbox_access_token_here
SQUARE_LOCATION_ID=your_sandbox_location_id_here
SQUARE_ENVIRONMENT=sandbox

# Production (live payments) - uncomment when ready
# SQUARE_ACCESS_TOKEN=your_production_access_token_here
# SQUARE_LOCATION_ID=your_location_id_here
# SQUARE_ENVIRONMENT=production

# Server
PORT=3000

# Promo Codes
# PROMO_FREE - Code that grants 100% discount (completely free)
# PROMO_DISCOUNT - Code that grants 15% discount
PROMO_FREE=FREE2DAY4
PROMO_DISCOUNT=SAVE15

# Email Configuration (choose one method)
# Option 1: Gmail (requires app password, not regular password)
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password
# EMAIL_FROM=Parser Profile <your-email@gmail.com>

# Option 2: Custom SMTP (any provider)
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-username
# SMTP_PASS=your-smtp-password
# EMAIL_FROM=Parser Profile <noreply@cognitionblocksllc.com>
